# Template de variables de entorno (Copia este archivo como Backend-Diagnostico-vocacional/.env)
# En Render, configura estas mismas variables en el panel "Environment".

# Servidor
PORT=5000
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/diagnostico_vocacional
JWT_SECRET=tu_secreto_aqui

# IA en la nube (OpenRouter) — crea tu key gratis en https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=tu_key_de_openrouter
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_FALLBACK_MODELS=google/gemma-4-31b-it:free,meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-next-80b-a3b-instruct:free,meta-llama/llama-3.2-3b-instruct:free

# Frontend (CORS) — admite varios orígenes separados por coma
# Ej: https://tu-app.vercel.app,http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Telegram (opcional). Crea el bot con @BotFather. Sin estas vars, el bot se desactiva.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
